rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Same single-user gate as Firestore. Lock to dad's email after first
    // sign-in:
    //   allow read, write: if request.auth.token.email == 'dad@example.com';
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
