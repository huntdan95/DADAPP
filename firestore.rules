rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SINGLE-USER GATE.
    // Currently allows any signed-in Google account because we don't yet
    // know dad's exact email. After his first sign-in, replace the rule
    // below with:
    //   allow read, write: if request.auth.token.email == 'dad@example.com';
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
