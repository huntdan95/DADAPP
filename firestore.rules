rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Single-user gate. Replace 'dad@example.com' with the real email
    // before deploy. Auth approach picked per plan §16: Firebase Auth.
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'dad@example.com';
    }
  }
}
