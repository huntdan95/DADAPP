rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Future allowlist gate (uncomment + populate when ready). For now any
    // signed-in Google account works; once you give me dad's + your friends'
    // emails, replace `signedIn()` below.
    function signedIn() {
      return request.auth != null;
      // return request.auth != null && request.auth.token.email in [
      //   'dad@example.com',
      //   'friend1@example.com',
      //   'friend2@example.com'
      // ];
    }

    // Legacy shared `locations` collection (pre-May 2026). New writes
    // go to `users/{uid}/locations/{id}` — see the per-user block
    // below. Reads stay open so the one-shot client-side migration
    // (lib/store/legacyMigration.ts) can copy existing docs into the
    // signed-in user's subcollection. Writes are blocked so nothing
    // accidentally lands here again.
    match /locations/{loc} {
      allow read: if signedIn();
      allow write: if false;
    }
    // Shared collaborative collections — every signed-in user can read+write.
    match /damSchedules/{key} {
      allow read, write: if signedIn();
    }
    match /boatLaunchSets/{state} {
      // Boat launches are seeded by Cloud Functions but we want clients
      // to read them. Writes are intended to come from the seeder
      // (admin SDK, which bypasses these rules). A signed-in client can
      // also write — fine for now, lock down later if abuse.
      allow read, write: if signedIn();
    }
    match /stockingEvents/{id} {
      // Shared stocking intel — any group member can add entries and
      // everyone reads them. Auto-scrapers (Cloud Functions, admin SDK)
      // will also write here.
      allow read, write: if signedIn();
    }

    match /briefings/{cacheKey} {
      // Shared "How's the bite?" cache. Any signed-in user can read so
      // the group amortizes the cost of generating each briefing. Writes
      // are server-only (the briefing Cloud Function uses the admin SDK
      // which bypasses rules) — clients should NEVER write directly,
      // since the contents have to come from a real Claude call.
      allow read: if signedIn();
      allow write: if false;
    }

    // Per-user private collections — your trips are yours.
    match /users/{uid}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // AI usage counters at aiUsage/{uid}/days/{date} — written by
    // Cloud Functions (admin SDK, bypasses these rules) and read by
    // the user's own SystemHealth dashboard. Read-only from the
    // client to prevent users from zeroing out their own caps.
    match /aiUsage/{uid}/{document=**} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Catches are stored under users/{uid}/trips/{tripId}/catches —
    // already covered by the rule above for direct access. Allow
    // collectionGroup queries on catches scoped to the requesting user
    // via the stamped userId field.
    match /{path=**}/catches/{catchId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
