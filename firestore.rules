rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Future allowlist gate (uncomment + populate when ready). For now any
    // signed-in Google account works; once you give me dad's + your friends'
    // emails, replace `signedIn()` below.
    function signedIn() {
      return request.auth != null;
      // return request.auth != null && request.auth.token.email in [
      //   'dad@example.com',
      //   'friend1@example.com',
      //   'friend2@example.com'
      // ];
    }

    // Shared collaborative collections — every signed-in user can read+write.
    match /locations/{loc} {
      allow read, write: if signedIn();
    }
    match /damSchedules/{key} {
      allow read, write: if signedIn();
    }
    match /boatLaunchSets/{state} {
      // Boat launches are seeded by Cloud Functions but we want clients
      // to read them. Writes are intended to come from the seeder
      // (admin SDK, which bypasses these rules). A signed-in client can
      // also write — fine for now, lock down later if abuse.
      allow read, write: if signedIn();
    }

    // Per-user private collections — your trips are yours.
    match /users/{uid}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Catches are stored under users/{uid}/trips/{tripId}/catches —
    // already covered by the rule above for direct access. Allow
    // collectionGroup queries on catches scoped to the requesting user
    // via the stamped userId field.
    match /{path=**}/catches/{catchId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
